# Copy to .env and fill in real values before deploying.
# cp .env.example .env

# HTTP port for the internal SFU API (FastAPI calls this; not public-facing)
PORT=3000

# Shared secret — must match MEDIASOUP_INTERNAL_SECRET in backend/.env
# Generate a secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=REPLACE_WITH_A_REAL_SECRET

# Number of mediasoup workers to spawn.
# Recommended: match your VPS CPU count (e.g. nproc --all).
# Using more than one requires the ConnectionManager to be backed by Redis
# pub/sub if the FastAPI backend also runs multiple workers.
WORKER_COUNT=1
WORKER_LOG_LEVEL=warn

# UDP port range allocated to mediasoup for RTP/RTCP media.
# These ports must be open in your firewall:
#   sudo ufw allow 40000:40100/udp
# And exposed in docker-compose.yml:
#   ports: ["40000-40100:40000-40100/udp"]
RTC_MIN_PORT=40000
RTC_MAX_PORT=40100

# Network — CRITICAL for cross-device / remote client connectivity.
# MEDIASOUP_LISTEN_IP:    the IP mediasoup workers bind to (0.0.0.0 = all interfaces)
# MEDIASOUP_ANNOUNCED_IP: the IP browsers will use to reach the server.
#
# On a VPS this MUST be the VPS public IPv4 address, e.g. 203.0.113.42.
# If left as 127.0.0.1, remote browsers receive a loopback candidate and
# media never flows.
#
# Find your VPS public IP:  curl -s https://api.ipify.org
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=REPLACE_WITH_YOUR_VPS_PUBLIC_IP
