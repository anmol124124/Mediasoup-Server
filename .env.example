# Copy to .env and adjust
# cp .env.example .env

PORT=3000

# Shared secret — must match MEDIASOUP_INTERNAL_SECRET in FastAPI .env
INTERNAL_SECRET=change-this-secret-in-production

# Number of mediasoup workers (1 for dev, os.cpus().length for prod)
WORKER_COUNT=1
WORKER_LOG_LEVEL=warn

# UDP port range for RTP/RTCP — must be exposed in docker-compose
RTC_MIN_PORT=40000
RTC_MAX_PORT=40100

# Network — set MEDIASOUP_ANNOUNCED_IP to your LAN/public IP for cross-device testing.
# 127.0.0.1 works when browser and server are on the same machine.
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
